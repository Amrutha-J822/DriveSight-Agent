DRIVESIGHT_DB_PATH=./data/drivesight.db
DRIVESIGHT_UPLOAD_DIR=./uploads

# YOLO settings. Use a local model path to avoid downloads during app startup.
# Windows example: C:\models\yolov8n.pt
# Project-local example: .\models\yolov8n.pt
YOLO_MODEL_PATH=./models/yolov8n.pt

# Optional OpenAI-compatible LLM service.
# Leave these empty to use the built-in heuristic brief generator.
LLM_PROVIDER=local
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
